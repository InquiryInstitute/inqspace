# Copy to .env in this directory (docs/) for local builds.
# GitHub Actions (optional): repository secret PUBLIC_INQSPACE_API_URL when the API is not same-origin /api.

# Optional: full base URL of the iNQspace API (include /api if Express mounts the router there).
# If unset, the browser uses {current origin}/api at runtime (dynamic). Override for cross-origin APIs.
# PUBLIC_INQSPACE_API_URL=https://your-api-xxxxx.run.app/api

# This deployment’s GitHub repo (owner/name). CI sets this to github.repository; set locally for your fork.
# PUBLIC_IDE_DEMO_REPO=myorg/my-course
