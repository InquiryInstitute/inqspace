# Copy to .env in this directory (docs/) for local builds.
# GitHub Pages: set Actions secret PUBLIC_INQSPACE_API_URL to your real API (Pages does not run Express at /api).

# Full base URL of the iNQspace API (include /api if Express mounts the router there).
# Required for production static hosting unless you use inqspace-api.json or a reverse proxy (see below).
# PUBLIC_INQSPACE_API_URL=https://your-api-xxxxx.run.app/api

# Set true only if a reverse proxy serves the API at {origin}/api on the same hostname as the site.
# PUBLIC_INQSPACE_SAME_ORIGIN_API=true

# This deployment’s GitHub repo (owner/name). CI sets this to github.repository; set locally for your fork.
# PUBLIC_IDE_DEMO_REPO=myorg/my-course
