# Copy to .env in this directory (docs/) for local builds.
# GitHub Actions: set repository secret PUBLIC_INQSPACE_API_URL (and optionally PUBLIC_IDE_DEMO_REPO).

# Base URL of the iNQspace API (include /api if your Express app mounts the router there).
# The docs site calls POST {PUBLIC_INQSPACE_API_URL}/ide/launch — no static code-server iframe URL.
# If unset, the browser falls back to public/inqspace-api.json { "apiBase": "…" } (commit that file for Pages).
PUBLIC_INQSPACE_API_URL=https://your-api-xxxxx.run.app/api

# Default owner/repo for the home page iframe when ?repo= is omitted (build-time).
PUBLIC_IDE_DEMO_REPO=InquiryInstitute/inqspace
