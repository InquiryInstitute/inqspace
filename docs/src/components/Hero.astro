---
const base = import.meta.env.BASE_URL;
const demoPageHref = `${base}demo/vscode-iframe`;
/** Base URL of iNQspace API (must include /api if your app mounts the router there). */
const apiBase = (import.meta.env.PUBLIC_INQSPACE_API_URL ?? '').trim().replace(/\/$/, '');
/** Default owner/repo when no ?repo= query (build-time). */
const defaultRepo =
  (import.meta.env.PUBLIC_IDE_DEMO_REPO ?? '').trim() || 'InquiryInstitute/inqspace';
---

<section class="hero">
  <div class="hero-inner">
    <div class="badge">Open Source Learning Platform</div>
    <h1>
      One course repo,<br />
      <span class="accent">many assignments</span> that build on each other
    </h1>
    <p class="subtitle">
      iNQspace connects GitHub Organizations to inquiry-driven courses. Students fork the
      <strong>course repository once</strong> and keep working in the same tree: assignments are
      logical units (deadlines, paths, requirements) layered on shared code and docs, not a new
      repo per lab. Submit via pull requests, grade in the PR flow, and pair with Jupyter Book,
      devcontainers, and an embedded IDE where you need it.
    </p>
    <div class="hero-actions">
      <a href="https://github.com/InquiryInstitute/inqspace" class="btn btn-primary" target="_blank" rel="noopener">
        View on GitHub
      </a>
      <a href="#features" class="btn btn-secondary">
        Explore Features
      </a>
    </div>
  </div>

  <div id="embed" class="hero-embed" aria-label="Embedded IDE preview">
    <p class="embed-kicker">Embedded IDE</p>
    <p class="embed-lede">
      The page asks the iNQspace API to provision code-server for a repo and returns the Cloud Run URL for this
      iframe—no static editor URL. Use <code>?repo=owner/name</code> and optional <code>&amp;ref=branch</code>; default
      repo comes from <code>PUBLIC_IDE_DEMO_REPO</code> at build time.
    </p>
    <div class="embed-frame" id="ide-embed-root">
      <p id="ide-embed-status" class="embed-status">Starting editor…</p>
      <iframe id="ide-embed-frame" hidden title="VS Code (code-server)"></iframe>
    </div>
    <p class="embed-footer">
      <a href={demoPageHref} class="embed-link">Open iframe demo page</a>
      <span class="embed-sep">·</span>
      <span class="embed-note">API must allow this site’s origin (CORS) and provisioner must allowlist it on code-server.</span>
    </p>
  </div>

  <div class="hero-glow" aria-hidden="true"></div>
</section>

<script define:vars={{ apiBase, defaultRepo }}>
  (function () {
    const statusEl = document.getElementById('ide-embed-status');
    const frame = document.getElementById('ide-embed-frame');
    if (!apiBase) {
      if (statusEl) {
        statusEl.textContent =
          'Set PUBLIC_INQSPACE_API_URL (iNQspace API base, e.g. https://your-api.run.app/api) at build time so this page can call POST …/ide/launch.';
      }
      return;
    }
    if (!frame) return;
    async function run() {
      try {
        const params = new URLSearchParams(window.location.search);
        const repoParam = params.get('repo');
        const ref = params.get('ref') || 'main';
        const parts = repoParam ? repoParam.split('/') : defaultRepo.split('/');
        const owner = parts[0];
        const repo = parts[1];
        if (!owner || !repo) throw new Error('Missing owner or repo');
        const res = await fetch(apiBase + '/ide/launch', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ owner, repo, ref }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          const msg = data.error?.message || data.error?.code || res.statusText;
          throw new Error(msg || 'Launch failed');
        }
        const serviceUrl = data.serviceUrl;
        if (!serviceUrl || typeof serviceUrl !== 'string') throw new Error('No serviceUrl in response');
        frame.src = serviceUrl;
        frame.loading = 'lazy';
        frame.referrerPolicy = 'strict-origin-when-cross-origin';
        frame.setAttribute('allow', 'clipboard-read; clipboard-write');
        frame.removeAttribute('hidden');
        if (statusEl) statusEl.style.display = 'none';
      } catch (e) {
        const msg = e instanceof Error ? e.message : String(e);
        if (statusEl) statusEl.textContent = 'Could not launch editor: ' + msg;
      }
    }
    run();
  })();
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 10rem 1.5rem 4rem;
    text-align: center;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-light);
    background: var(--color-accent-glow);
    border: 1px solid rgba(99, 102, 241, 0.3);
    padding: 0.35rem 1rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .accent {
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-success));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
  }

  .btn-primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--color-accent-light);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.3);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-surface-hover);
    transform: translateY(-1px);
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-embed {
    position: relative;
    z-index: 1;
    max-width: 960px;
    margin: 3rem auto 0;
    padding: 0 1.5rem 2rem;
    text-align: center;
  }

  .embed-kicker {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-light);
    margin-bottom: 0.5rem;
  }

  .embed-lede {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 52ch;
    margin: 0 auto 1.25rem;
  }

  .embed-frame {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: #1e1e1e;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  }

  .embed-frame iframe:not([hidden]) {
    display: block;
    width: 100%;
    height: min(52vh, 440px);
    border: 0;
    background: #1e1e1e;
  }

  .embed-status {
    min-height: min(52vh, 440px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    text-align: left;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 52ch;
    margin: 0 auto;
  }

  .embed-status:empty {
    display: none;
  }

  .embed-frame iframe[hidden] {
    display: none !important;
  }

  .embed-footer {
    margin-top: 1rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .embed-link {
    font-weight: 600;
    color: var(--color-accent-light);
  }

  .embed-link:hover {
    color: var(--color-accent);
  }

  .embed-sep {
    margin: 0 0.35rem;
    opacity: 0.6;
  }

  .embed-note {
    opacity: 0.9;
  }

  @media (max-width: 640px) {
    .embed-frame iframe:not([hidden]) {
      height: min(42vh, 320px);
    }

    .embed-note {
      display: block;
      margin-top: 0.35rem;
    }

    .embed-sep {
      display: none;
    }
  }
</style>
