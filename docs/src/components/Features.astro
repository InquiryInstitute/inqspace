---
const features = [
  {
    icon: '🏫',
    title: 'Course Management',
    description:
      'Courses are backed by GitHub Organizations: one canonical upstream repository per course, with teams and permissions scoped the way you expect.',
  },
  {
    icon: '🌿',
    title: 'One fork per student',
    description:
      'Each student forks the course repository once and keeps a single long-lived workspace. Later assignments extend earlier work in the same repo instead of starting from scratch.',
  },
  {
    icon: '📋',
    title: 'Assignment workflows',
    description:
      'Assignments are metadata on top of the shared repo: due dates, requirements, and optional paths within the tree. Students build on prior modules naturally.',
  },
  {
    icon: '🔀',
    title: 'Pull request submissions',
    description:
      'Submissions are pull requests against the course upstream. Review inline, comment on lines, and grade where the code already lives.',
  },
  {
    icon: '📖',
    title: 'Jupyter Book',
    description:
      'First-class support for Jupyter Book: course- and assignment-level paths, defaults for _config.yml / _toc.yml, and published book URLs (e.g. GitHub Pages) wired into the API.',
  },
  {
    icon: '📦',
    title: 'Devcontainer support',
    description:
      'Standard devcontainer.json for the course repo: one environment for the whole term, aligned with GitHub Codespaces and local Docker workflows.',
  },
  {
    icon: '🔐',
    title: 'Dual authentication',
    description:
      'GitHub OAuth for repository access and Google Workspace for institutional identity. Tokens are encrypted at rest.',
  },
  {
    icon: '🔔',
    title: 'Smart notifications',
    description:
      'Deadlines, late work, upstream course changes, and grading updates—so students know when to sync or resubmit.',
  },
  {
    icon: '📊',
    title: 'Grading & feedback',
    description:
      'Structured scores, inline feedback, and optional auto-grading hooks. The same PR-centric workflow instructors already use on GitHub.',
  },
];
---

<section id="features" class="features">
  <div class="section-inner">
    <h2>Built for cumulative, code-centric courses</h2>
    <p class="section-desc">
      One repository, one fork per learner, many assignments that stack—books, notebooks, tests, and
      IDE embeds on the same platform.
    </p>
    <div class="grid">
      {features.map((f) => (
        <div class="card">
          <span class="card-icon">{f.icon}</span>
          <h3>{f.title}</h3>
          <p>{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding: 5rem 1.5rem;
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .section-desc {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    text-align: left;
  }

  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.25s;
  }

  .card:hover {
    border-color: rgba(99, 102, 241, 0.4);
    background: var(--color-surface-hover);
    transform: translateY(-2px);
  }

  .card-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }
</style>
