---
const layers = [
  {
    name: 'Integration Layer',
    color: '#6366f1',
    items: ['GitHub API Client', 'Google Workspace', 'OAuth Providers'],
    description: 'Abstracts external service communication behind clean interfaces.',
  },
  {
    name: 'Application Layer',
    color: '#818cf8',
    items: [
      'Course Management',
      'Assignment Service',
      'Jupyter Book',
      'Auth',
      'Grading',
      'Sync',
    ],
    description: 'Orchestrates business logic, enforces rules, and coordinates between layers.',
  },
  {
    name: 'Data Layer',
    color: '#a5b4fc',
    items: ['Course Repo', 'Assignment Repo', 'Fork Repo', 'User Repo', 'Submission Repo'],
    description: 'Repository pattern for persistence; forks are keyed per course and student.',
  },
];

const models = [
  { name: 'Course', desc: 'Org + canonical upstream repository for the term' },
  { name: 'Assignment', desc: 'Logical unit of work within the course repo (not a separate repo)' },
  { name: 'Fork', desc: "Student's copy of the course repository" },
  { name: 'User', desc: 'Students, instructors, and admins' },
  { name: 'Submission', desc: 'PR-based submission to the course upstream' },
  { name: 'AuthToken', desc: 'Encrypted OAuth credentials' },
  { name: 'DevcontainerConfig', desc: 'Reproducible dev environments' },
  { name: 'Notification', desc: 'Event-driven system alerts' },
];
---

<section id="architecture" class="architecture">
  <div class="section-inner">
    <h2>Three-tier architecture</h2>
    <p class="section-desc">
      Clean separation of concerns with typed interfaces at every boundary.
      Built in TypeScript with strict mode for maximum safety.
    </p>

    <div class="layers">
      {layers.map((layer) => (
        <div class="layer" style={`--layer-color: ${layer.color}`}>
          <div class="layer-header">
            <div class="layer-dot" />
            <h3>{layer.name}</h3>
          </div>
          <p class="layer-desc">{layer.description}</p>
          <div class="layer-items">
            {layer.items.map((item) => (
              <span class="layer-item">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <h3 class="models-title">Core data models</h3>
    <div class="models-grid">
      {models.map((m) => (
        <div class="model">
          <code>{m.name}</code>
          <span>{m.desc}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .architecture {
    padding: 5rem 1.5rem;
    background: var(--color-bg-alt);
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .section-desc {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .layers {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto 3.5rem;
    text-align: left;
  }

  .layer {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--layer-color);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
  }

  .layer-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }

  .layer-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--layer-color);
  }

  .layer h3 {
    font-size: 1rem;
    font-weight: 600;
  }

  .layer-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .layer-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .layer-item {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.2);
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    color: var(--color-accent-light);
  }

  .models-title {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .models-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.75rem;
    text-align: left;
  }

  .model {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
  }

  .model code {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent-light);
    background: none;
    padding: 0;
  }

  .model span {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
