---
const base = import.meta.env.BASE_URL;
---

<nav>
  <div class="nav-inner">
    <a href={base} class="logo">
      <span class="logo-mark">iNQ</span><span class="logo-rest">space</span>
    </a>
    <div class="nav-links">
      <a href={`${base}demo/vscode-iframe`}>VS Code iframe</a>
      <a href={`${base}#embed`}>Embed</a>
      <a href={`${base}#features`}>Features</a>
      <a href={`${base}#architecture`}>Architecture</a>
      <a href={`${base}#workflow`}>Workflow</a>
      <a href="https://github.com/InquiryInstitute/inqspace" class="btn-github" target="_blank" rel="noopener">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 14, 26, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .logo-mark {
    color: var(--color-accent-light);
  }

  .logo-rest {
    color: var(--color-text);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  .btn-github {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--color-surface);
    padding: 0.4rem 0.85rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    transition: all 0.2s;
  }

  .btn-github:hover {
    background: var(--color-surface-hover);
    color: var(--color-text) !important;
  }

  @media (max-width: 640px) {
    .nav-links a:not(.btn-github) {
      display: none;
    }
  }
</style>
