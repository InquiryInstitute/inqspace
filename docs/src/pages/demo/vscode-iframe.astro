---
import Base from '../../layouts/Base.astro';
import { siteGithubRepo } from '../../config/site';

const base = import.meta.env.BASE_URL;
const defaultRepo = siteGithubRepo;
const [placeholderOwner, placeholderRepo] = (() => {
  const p = siteGithubRepo.split('/');
  return [p[0] || 'owner', p[1] || 'repo'];
})();
---

<Base
  title="VS Code in an iframe — iNQspace demo"
  description="Launch code-server via iNQspace API (POST /ide/launch) for a GitHub repo—no static iframe URL."
>
  <div class="page">
    <header class="header">
      <a class="back" href={base}>← iNQspace</a>
      <h1>VS Code in an iframe</h1>
      <p class="lede">
        <strong>Launch</strong> → the API provisions <strong>Cloud Run</strong> (code-server) for the repo → response
        includes <code>serviceUrl</code> → this page sets <code>iframe.src</code> to that URL. Configure the API base via
        <code>PUBLIC_INQSPACE_API_URL</code> or <code>/inqspace-api.json</code> when the API is not on the same host.
      </p>
    </header>

    <div id="ide-page-config" hidden data-default-repo={defaultRepo}></div>

    <section class="controls" aria-label="Repository">
      <label for="ide-owner">Owner / repo / ref</label>
      <div class="row">
        <input id="ide-owner" type="text" placeholder={placeholderOwner} autocomplete="off" />
        <input id="ide-repo" type="text" placeholder={placeholderRepo} autocomplete="off" />
        <input id="ide-ref" type="text" placeholder="main" autocomplete="off" />
        <button type="button" id="btn-launch" class="btn primary">Launch</button>
      </div>
      <p class="hint">
        Or use query <code>?repo=owner/name&amp;ref=main</code> on the home page. Ensure the API allows this origin (CORS)
        and code-server <code>TRUSTED_ORIGINS</code> includes your Pages hostname.
      </p>
    </section>

    <section class="frame-wrap" aria-label="Embedded editor">
      <div class="frame-label">iframe</div>
      <p id="ide-status" class="frame-status">Idle — click Launch or load with query params.</p>
      <iframe id="ide-frame" hidden title="VS Code (code-server)"></iframe>
    </section>

    <section class="log" aria-live="polite">
      <h2>postMessage log</h2>
      <p class="muted">Optional: parent page can listen for <code>postMessage</code> from the embedded origin.</p>
      <pre id="msg-log" class="msg-log">(waiting for messages…)</pre>
    </section>
  </div>
</Base>

<script>
  import { resolveApiBase } from '../../utils/resolveApiBase';
  import { siteGithubRepo } from '../../config/site';

  const cfg = document.getElementById('ide-page-config');
  const defaultRepo =
    (cfg?.getAttribute('data-default-repo') || siteGithubRepo).trim() || siteGithubRepo;

  const ownerIn = document.getElementById('ide-owner');
  const repoIn = document.getElementById('ide-repo');
  const refIn = document.getElementById('ide-ref');
  const statusEl = document.getElementById('ide-status');
  const frame = document.getElementById('ide-frame');
  const logEl = document.getElementById('msg-log');

  const parts = defaultRepo.split('/');
  if (ownerIn && parts[0]) ownerIn.value = parts[0];
  if (repoIn && parts[1]) repoIn.value = parts[1];
  if (refIn) refIn.value = 'main';

  function appendLog(line) {
    const t = new Date().toISOString().slice(11, 23);
    if (!logEl) return;
    logEl.textContent = `[${t}] ${line}\n` + (logEl.textContent === '(waiting for messages…)' ? '' : logEl.textContent);
  }

  let cachedApiBase = null;
  async function getApiBase() {
    if (cachedApiBase !== null) return cachedApiBase;
    cachedApiBase = await resolveApiBase(import.meta.env.PUBLIC_INQSPACE_API_URL ?? '');
    return cachedApiBase;
  }

  async function launchFromInputs() {
    const apiBase = await getApiBase();
    if (!apiBase) {
      if (statusEl)
        statusEl.textContent =
          'Set GitHub secret PUBLIC_INQSPACE_API_URL, or docs/public/inqspace-api.json apiBase — see docs/README.md. Redeploy Pages.';
      appendLog('error: no API base');
      return;
    }
    const owner = (ownerIn?.value || '').trim();
    const repo = (repoIn?.value || '').trim();
    const ref = (refIn?.value || '').trim() || 'main';
    if (!owner || !repo) {
      if (statusEl) statusEl.textContent = 'Enter owner and repo.';
      return;
    }
    if (statusEl) statusEl.textContent = 'Launching…';
    if (!frame) return;
    try {
      const res = await fetch(apiBase + '/ide/launch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ owner, repo, ref }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error?.message || res.statusText);
      const serviceUrl = data.serviceUrl;
      if (!serviceUrl) throw new Error('No serviceUrl');
      if (data.status != null && data.status !== 'ready') throw new Error('Unexpected launch status');
      if (statusEl) statusEl.textContent = 'Opening editor…';
      frame.src = serviceUrl;
      frame.loading = 'lazy';
      frame.referrerPolicy = 'strict-origin-when-cross-origin';
      frame.setAttribute('allow', 'clipboard-read; clipboard-write');
      frame.removeAttribute('hidden');
      if (statusEl) statusEl.style.display = 'none';
      appendLog('ready — serviceUrl from launch: ' + serviceUrl);
    } catch (e) {
      const msg = e instanceof Error ? e.message : String(e);
      if (statusEl) {
        statusEl.style.display = '';
        statusEl.textContent = 'Error: ' + msg;
      }
      appendLog('error: ' + msg);
    }
  }

  document.getElementById('btn-launch')?.addEventListener('click', launchFromInputs);

  (function autoFromQuery() {
    const params = new URLSearchParams(window.location.search);
    const r = params.get('repo');
    if (r && r.includes('/')) {
      const [o, rep] = r.split('/');
      if (ownerIn) ownerIn.value = o;
      if (repoIn) repoIn.value = rep;
      if (params.get('ref') && refIn) refIn.value = params.get('ref') || 'main';
      launchFromInputs();
    }
  })();

  window.addEventListener('message', (ev) => {
    appendLog('postMessage from ' + (ev.origin || '?'));
  });
</script>

<style>
  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 5rem 1.5rem 3rem;
  }

  .header .back {
    display: inline-block;
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .header .back:hover {
    color: var(--color-accent-light);
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .lede {
    color: var(--color-text-muted);
    max-width: 65ch;
    font-size: 1rem;
    line-height: 1.65;
  }

  .lede code {
    font-size: 0.88em;
  }

  .controls {
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .controls label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text-muted);
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .row input {
    flex: 1;
    min-width: 120px;
    padding: 0.6rem 0.85rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .btn {
    padding: 0.55rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn:hover {
    background: var(--color-surface-hover);
  }

  .btn.primary {
    background: var(--color-accent);
    border-color: transparent;
    color: #fff;
  }

  .btn.primary:hover {
    filter: brightness(1.08);
  }

  .hint {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    max-width: 75ch;
  }

  .frame-wrap {
    margin-top: 1.5rem;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: #1e1e1e;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  }

  .frame-label {
    position: absolute;
    top: 8px;
    right: 10px;
    z-index: 2;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.45);
    pointer-events: none;
  }

  .frame-status {
    min-height: 120px;
    padding: 1.5rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  #ide-frame:not([hidden]) {
    display: block;
    width: 100%;
    height: min(72vh, 640px);
    border: 0;
    background: #1e1e1e;
  }

  #ide-frame[hidden] {
    display: none !important;
  }

  .log {
    margin-top: 2rem;
  }

  .log h2 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .muted {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
    max-width: 70ch;
  }

  .msg-log {
    padding: 1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: pre-wrap;
    word-break: break-all;
    max-height: 180px;
    overflow: auto;
  }
</style>
